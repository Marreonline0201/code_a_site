# .env.example - copy to .env.local and fill in real values
#
# Get Supabase values from your project dashboard:
# https://supabase.com/dashboard/project/_/settings/api

# Client-safe (public - RLS protects data, these are safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
NEXT_PUBLIC_AMAZON_TAG=your-affiliate-tag
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only secrets (NEVER prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard

# Local CSV source for the NYC tap-water backend
NYC_WATER_SAMPLES_CSV_PATH=data/nyc-lead-testing.csv
NYC_WATER_ZIP_TRENDS_CSV_PATH=data/lead-testing2.csv

# Supabase Dashboard Configuration
#
# 1. Authentication > Providers > Email:
#    - Enable Email provider
#    - Enable "Confirm email" (required for email verification flow)
#    - Minimum password length: 8
#    - Disable "Double confirm email changes" (one confirmation is enough)
#
# 2. Authentication > Providers > Google (optional):
#    - Enable Google provider
#    - Enter Google Client ID and Client Secret from Google Cloud Console
#    - Copy the Supabase redirect URI to your Google OAuth settings
#
# 3. Authentication > URL Configuration:
#    - Site URL: http://localhost:3000 (dev) / https://yourdomain.com (prod)
#    - Redirect URLs: http://localhost:3000/auth/callback
#    - Add production URLs when deploying
#
# 4. Authentication > Email Templates (optional):
#    - Customize Confirm signup, Reset password, Magic link templates
#    - Ensure confirmation URL points to /auth/callback
#
# 5. Authentication > Rate Limits:
#    - Email sign-ups: 3 per hour (default is adequate)
#    - Adjust password sign-in limits as needed
